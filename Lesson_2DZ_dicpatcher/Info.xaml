<Window x:Class="Lesson_2DZ_dicpatcher.Info"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DZ_dispatcher.Windows"
        mc:Ignorable="d"
        Title="Info" Height="228" Width="324">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0"
               Grid.Column="0"
               Content="ID:"/>

        <Label Grid.Row="0"
               Grid.Column="1"
               Content="{Binding Id}"/>

        <Label Grid.Row="1"
               Grid.Column="0"
               Content="Имя процесса:"/>

        <Label Grid.Row="1"
               Grid.Column="1"
               Content="{Binding ProcessName}"/>

        <Label Grid.Row="2"
               Grid.Column="0"
               Content="Память:"/>

        <Label Grid.Row="2"
               Grid.Column="1"
               Content="{Binding MemoryMb, StringFormat={}{0:N0} МБ}"/>

        <Label Grid.Row="3"
               Grid.Column="0"
               Content="Потоки:"/>

        <Label Grid.Row="3"
               Grid.Column="1"
               Content="{Binding ThreadsCount}"/>

        <Label Grid.Row="4"
               Grid.Column="0"
               Content="Время запуска:"/>

        <Label Grid.Row="4"
               Grid.Column="1"
               Content="{Binding StartTime, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"/>
    </Grid>
</Window>
