<Window x:Class="DZ_dispatcher.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DZ_dispatcher"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <Grid ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="20*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="tab_process"
                  Grid.Column="1" Grid.Row="1"
                  ItemsSource="{Binding ListProcess}"
                  SelectedItem="{Binding SelectProcess}"
                  
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  
                  IsReadOnly="True"
           
                  GridLinesVisibility="None"
                  FontSize="35" MouseDoubleClick="tab_process_MouseDoubleClick">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" 
                                    Binding="{Binding Name}"/>
                <DataGridTextColumn Header="ЦП" 
                                    Binding="{Binding CPU,StringFormat={}{0:P1}}"/>
                <DataGridTextColumn Header="Память" 
                                    Binding="{Binding OZY, StringFormat={}{0:N0} МБ}" />
            </DataGrid.Columns>
           

        </DataGrid>
        <Button x:Name="bt_update" Content="Обновить"
                Grid.Row="0" Grid.Column="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                FontSize="25" Command="{Binding cUpdate}"/>

    </Grid>
</Window>
